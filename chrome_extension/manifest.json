{
  "name": "caalm web",
  "description": "an internet for humans",
  "manifest_version": 3,
  "version": "1.3",
  "host_permissions": [
    "<all_urls>"
  ],
  "permissions": [
    "contextMenus",
    "storage",
    "scripting",
    "activeTab"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "css": ["nolist.css"],
      "js": ["user_blocklist.js"]
    },
    {
      "matches": ["*://*.amazon.com/*"],
      "js": ["amazon.js"],
      "css": ["amazon.css"]
    },
    {
      "matches": ["*://*.facebook.com/*"],
      "js": ["facebook.js"],
      "css": ["facebook.css"]
    },
    {
      "matches": ["*://*.linkedin.com/*"],
      "js": ["linkedin.js"],
      "css": ["linkedin.css"]
    }
  ],
  "icons": {
    "48": "icon-48.png"
  }
}
